---
import SectionHeader from "@/components/elements/SectionHeader.astro";
import Matter from "@/components/ui/Matter.astro";
import Button from "@/components/ui/Button.astro";
import Tools from "../ui/Tools.astro";
interface Props {
  title?: string;
  description?: string;
}
const {title, description
} = Astro.props;

// 视频封面数据
const videoCovers = [
  { id: 1, image: "/assets/videos/sony-boy.webp", alt: "Sony Boy" },
  { id: 2, image: "/assets/videos/qiu.webp", alt: "秋" },
  { id: 3, image: "/assets/videos/nv-daxuesheng-de-yitian-meme.webp", alt: "女大学生的一天" },
  { id: 4, image: "/assets/videos/hudielan.webp", alt: "蝴蝶兰" },
];
---

<section class="py-8 sm:py-12 md:py-16 md:pb-12 site-container">
    <div class="space-y-6 sm:space-y-8 md:space-y-8">
      <SectionHeader title={title} description={description}/>
    </div>

    <div class="explore-content w-full relative mt-6 sm:mt-8">
        <div class="explore-list w-full relative grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
            <!-- 第一列 -->
            <div class="explore-column explore-column-1 w-full flex gap-3 sm:gap-4 flex-col">
                <a href="/works" class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-1 h-[200px] sm:h-[220px] md:h-[264px] block cursor-pointer hover:border-primary/30 transition-colors"
                data-aos="fade-up-sm"
                data-aos-delay="500"
                data-aos-duration="600"
                data-aos-once="true">
                    <div class="content">
                        <h3>设计&开发</h3>
                        <p>把创意和想法落地为真实的项目</p>
                    </div>
                    <div class="absolute keyboard right-[-35%] sm:right-[-50%] md:right-[-58%] bottom-0 top-0 flex items-center self-center w-[300px] sm:w-[320px] md:w-[390px] h-auto">
                        <img src="/assets/tools/keyboard.webp" alt="键盘" class="w-full h-full object-cover">
                    </div>
                </a>
                <a href="/video" class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-2 h-[180px] sm:h-[200px] block cursor-pointer hover:border-primary/30 transition-colors"
  data-aos="fade-up-sm"
  data-aos-delay="600"
  data-aos-duration="600"
  data-aos-once="true">
                    <div class="content">
                        <h3>视频</h3>
                        <p>我觉得很棒的视频作品</p>
                    </div>
                    <div class="explore-figure video-container absolute right-0 bottom-0 top-0 w-full h-full">
                        {videoCovers.map((video, index) => (
                          <div class={`absolute video right-[-21%] bottom-0 top-0 flex items-center self-center w-auto h-[100px] sm:h-[120px] md:h-[130px] z-[${50 - index * 10}]`} data-video={index + 1} style={`margin-top: ${-10 + index * 5}%`}>
                              <img src={video.image} alt={video.alt} class="w-full h-full object-cover self-center flex rounded-lg shadow-lg">
                          </div>
                        ))}
                    </div>
                </a>
            </div>

            <!-- 第二列 -->
            <div class="explore-column explore-column-2 w-full flex gap-3 sm:gap-4 flex-col">
                <a href="/blog" class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-3 h-[180px] sm:h-[200px] block cursor-pointer hover:border-primary/30 transition-colors"
  data-aos="fade-up-sm"
  data-aos-delay="700"
  data-aos-duration="600"
  data-aos-once="true">
                    <div class="content">
                        <h3>写作</h3>
                        <p>风格指南、设计笔记和思考。</p>
                    </div>
                    <div class="explore-figure computer absolute right-[5%] sm:right-[-10%] md:right-[-7%] bottom-[14%] w-[120px] sm:w-[130px] md:w-[148px] h-auto">
                        <img src="/assets/tools/retro-computer.webp" alt="复古电脑" class="w-full h-full object-cover z-10 relative">
                        <div class="computer-screen absolute inset-0 w-[92px] sm:w-[100px] md:w-[116px] h-[76px] sm:h-[86px] md:h-[96px] top-[10.5%] left-[10%] rounded-[8px] rounded-b-[3px] overflow-hidden z-20">
                          <video
                            id="explore-computer-video"
                            src="/assets/tools/dreamcore.mp4"
                            poster="/assets/tools/dreamcore.webp"
                            autoplay
                            loop
                            muted
                            playsinline
                            webkit-playsinline
                            preload="auto"
                            controlslist="nodownload noplaybackrate nofullscreen noremoteplayback"
                            disablepictureinpicture
                            class="w-full h-full object-cover"
                          ></video>
                        </div>
                    </div>
                </a>
                <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark explore-item-3 relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-4 h-[200px] sm:h-[220px] md:h-[264px]"
  data-aos="fade-up-sm"
  data-aos-delay="800"
  data-aos-duration="600"
  data-aos-once="true">
                    <div class="content">
                        <h3>小狸</h3>
                        <p>可爱的半狸猫半人生物</p>
                    </div>
                    <div class=" explore-figure absolute machine right-[5%] sm:right-[-10%] md:right-[-7%] bottom-0 top-0 flex items-center">
                        <Tools />
                    </div>
                </div>
            </div>


            <div class="explore-column explore-column-3 w-full col-span-1 sm:col-span-2 lg:col-span-1">
                <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark explore-item-3 relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-5"
  data-aos="fade-up-sm"
  data-aos-delay="900"
  data-aos-duration="600"
  data-aos-once="true">
                    <div
                    class="explore-figure tool-stack-box relative rounded-xl overflow-hidden w-full h-[480px] sm:h-[400px] md:h-[480px]"
                    data-aos="fade-up-sm"
                    data-aos-delay="100"
                    data-aos-duration="600"
                    data-aos-once="true"
                    >
                        <Matter />
                        <div class="absolute inset-0 flex items-center justify-center text-white opacity-50">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .content{
        position: absolute;
        bottom: 0;
        left: 0;
        top: 0;
        max-width: 45%;
        padding-left:1rem;
        padding-right:0.5rem;
        display: flex;
        align-items: self-start;
        flex-direction: column;
        justify-content: center;
        transition: all 0.3s ease-in-out;
        z-index: 1;
    }

    @media (min-width: 640px) {
        .content {
            max-width: 55%;
            padding-left:1.25rem;
        }
    }

    @media (min-width: 768px) {
        .content {
            max-width: 50%;
            padding-left:1.5rem;
        }
    }

    .content h3{
        font-size: 1.25rem;
        line-height: 1.1;
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    @media (min-width: 640px) {
        .content h3 {
            font-size: 1.5rem;
        }
    }

    @media (min-width: 768px) {
        .content h3 {
            font-size: 1.75rem;
        }
    }

    .content p{
        font-size: 0.75rem;
        line-height: 1.3;
        font-weight: 400;
        color: var(--color-neutral-400);
    }

    @media (min-width: 640px) {
        .content p {
            font-size: 0.875rem;
        }
    }

    .explore-item:hover .content {
        transform: translateY(-5px);
    }

    /* 视频卡片堆叠效果 */
    .video-container .video:nth-child(1) { right: -21%; margin-top: -10%; z-index: 50; }
    .video-container .video:nth-child(2) { right: -19%; margin-top: -5%; z-index: 40; }
    .video-container .video:nth-child(3) { right: -16%; margin-top: 0%; z-index: 30; }
    .video-container .video:nth-child(4) { right: -13%; margin-top: 5%; z-index: 20; }
    .video-container .video:nth-child(5) { right: -10%; margin-top: 10%; z-index: 10; }

    .explore-item:hover .video-container .video {
        transition: all 0.4s ease;
    }

    .explore-item:hover .video-container .video:nth-child(1) { transform: translateX(-5px) rotate(-3deg); }
    .explore-item:hover .video-container .video:nth-child(2) { transform: translateX(-3px) rotate(-1deg); }
    .explore-item:hover .video-container .video:nth-child(3) { transform: translateX(0px) rotate(0deg); }
    .explore-item:hover .video-container .video:nth-child(4) { transform: translateX(3px) rotate(1deg); }
    .explore-item:hover .video-container .video:nth-child(5) { transform: translateX(5px) rotate(3deg); }

    .keyboard{
        transition: all 0.5s ease;
    }

    .explore-item:hover .keyboard {
        transform: translateY(-5px);
    }

    .computer{
        transition: all 0.5s ease;
    }

    .explore-item:hover .computer {
        transform: translateY(-5px);
    }

    .machine{
        transition: all 0.5s ease;
    }

    .explore-item:hover .machine {
        transform: translateY(-5px);
    }

    .explore-item:hover .game-container .game {
        transition: all 0.4s ease;
    }

    .explore-item:hover .game-container .game[data-game="1"] { transform: translateX(-15px) rotate(-8deg); }
    .explore-item:hover .game-container .game[data-game="2"] { transform: translateX(-10px) rotate(-4deg); }
    .explore-item:hover .game-container .game[data-game="3"] { transform: translateX(-5px) rotate(-2deg); }
    .explore-item:hover .game-container .game[data-game="4"] { transform: translateX(0px) rotate(0deg); }
    .explore-item:hover .game-container .game[data-game="5"] { transform: translateX(5px) rotate(2deg); }

    .explore-item:hover .btn {
        opacity: 1;
    }

    .tool-stack-box :global(canvas) {
        width: 100% !important;
        height: 100% !important;
    }

    .computer-screen {
        background: #000;
    }

    .computer-screen video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
</style>
