---
import PostLayout from "@/layouts/PostLayout.astro";
import { ArrowLeft, Sparkles, Music, Palette, ChevronLeft, ChevronRight } from "@lucide/astro";

// 柠檬味的设计 - 精选作品图片（不包含品牌标识）
const allImages = [
  { id: 1, name: "0326", image: "/assets/projects/x/0326.webp" },
  { id: 2, name: "唱片1", image: "/assets/projects/x/唱片1.webp" },
  { id: 3, name: "唱片2", image: "/assets/projects/x/唱片2.webp" },
  { id: 4, name: "磁盘1", image: "/assets/projects/x/磁盘1.webp" },
  { id: 5, name: "磁盘2", image: "/assets/projects/x/磁盘2.webp" },
  { id: 6, name: "超能", image: "/assets/projects/x/超能.webp" },
];

const brandImages = [
  { id: 1, name: "封面", image: "/assets/projects/x/品牌与标志规范/封面.webp" },
  { id: 2, name: "p0", image: "/assets/projects/x/品牌与标志规范/p0.webp" },
  { id: 3, name: "p1", image: "/assets/projects/x/品牌与标志规范/p1.webp" },
  { id: 4, name: "p2", image: "/assets/projects/x/品牌与标志规范/p2.webp" },
  { id: 5, name: "p3", image: "/assets/projects/x/品牌与标志规范/p3.webp" },
  { id: 6, name: "p4", image: "/assets/projects/x/品牌与标志规范/p4.webp" },
  { id: 7, name: "p5", image: "/assets/projects/x/品牌与标志规范/p5.webp" },
  { id: 8, name: "p6", image: "/assets/projects/x/品牌与标志规范/p6.webp" },
];
---

<PostLayout
  title="柠檬味的设计"
  description="这里存放了一些可能不成系统但能让人觉得清爽的练习！"
  keywords="设计, 音乐, 清爽"
>
  <div class="min-h-screen bg-background">
    <!-- 头部导航 -->
    <header class="relative z-10 py-6 px-4 md:px-8">
      <div class="max-w-7xl mx-auto">
        <a 
          href="/works" 
          class="inline-flex items-center gap-2 text-neutral-600 dark:text-neutral-400 hover:text-lime-600 transition-colors group"
        >
          <ArrowLeft size={20} class="group-hover:-translate-x-1 transition-transform" />
          <span class="font-medium">返回作品集</span>
        </a>
      </div>
    </header>

    <!-- 英雄区域 -->
    <section class="relative z-10 py-16 md:py-24 px-4 md:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <!-- 柠檬图标装饰 -->
        <div class="flex justify-center gap-4 mb-8">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-yellow-400 to-lime-500 flex items-center justify-center shadow-lg shadow-yellow-200/50 rotate-3 hover:rotate-6 transition-transform">
            <Sparkles class="text-white" size={28} />
          </div>
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-lime-400 to-emerald-500 flex items-center justify-center shadow-lg shadow-lime-200/50 -rotate-3 hover:-rotate-6 transition-transform">
            <Music class="text-white" size={28} />
          </div>
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center shadow-lg shadow-emerald-200/50 rotate-3 hover:rotate-6 transition-transform">
            <Palette class="text-white" size={28} />
          </div>
        </div>

        <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-yellow-500 via-lime-500 to-emerald-500 bg-clip-text text-transparent">
          柠檬味的设计
        </h1>
        
        <div class="flex flex-wrap justify-center gap-3 mb-8">
          <span class="px-4 py-2 rounded-full bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 text-sm font-medium">设计</span>
          <span class="px-4 py-2 rounded-full bg-lime-100 dark:bg-lime-900/30 text-lime-700 dark:text-lime-300 text-sm font-medium">音乐</span>
          <span class="px-4 py-2 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 text-sm font-medium">清爽</span>
        </div>

        <p class="text-xl md:text-2xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto leading-relaxed">
          这里存放了一些可能不成系统但能让人觉得清爽的练习！
        </p>
      </div>
    </section>

    <!-- 瀑布流展示区 - 所有图片 -->
    <section class="relative z-10 py-12 px-4 md:px-8">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-800 dark:text-neutral-200 mb-8 flex items-center gap-3">
          <span class="w-1 h-8 bg-gradient-to-b from-yellow-400 to-lime-500 rounded-full"></span>
          精选作品
        </h2>

        <!-- 瀑布流网格 -->
        <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
          {allImages.map((item, index) => (
            <div 
              class="break-inside-avoid group relative overflow-hidden rounded-2xl bg-white dark:bg-neutral-800 shadow-sm hover:shadow-xl transition-all duration-500"
              data-aos="fade-up"
              data-aos-delay={index * 50}
            >
              <div class="relative overflow-hidden">
                <img 
                  src={item.image} 
                  alt={item.name}
                  class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
                <!-- 悬停遮罩 -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <div class="absolute bottom-4 left-4 right-4">
                    <span class="inline-block px-3 py-1 rounded-full bg-white/90 text-neutral-800 text-sm font-medium">
                      {item.name}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 品牌标识规范轮播区 -->
    <section class="relative z-10 py-16 px-4 md:px-8 bg-neutral-50 dark:bg-neutral-900/50">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-800 dark:text-neutral-200 mb-8 flex items-center gap-3">
          <span class="w-1 h-8 bg-gradient-to-b from-lime-400 to-emerald-500 rounded-full"></span>
          品牌与标志规范
        </h2>

        <!-- 轮播容器 -->
        <div class="relative" id="brand-carousel">
          <!-- 轮播轨道 -->
          <div class="overflow-hidden rounded-2xl">
            <div class="flex transition-transform duration-500 ease-out" id="carousel-track">
              {brandImages.map((item) => (
                <div class="w-full flex-shrink-0 px-2">
                  <div class="relative overflow-hidden rounded-2xl bg-white dark:bg-neutral-800 shadow-lg">
                    <img 
                      src={item.image} 
                      alt={item.name}
                      class="w-full h-auto object-cover"
                      loading="lazy"
                    />
                    <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/60 to-transparent">
                      <span class="text-white font-medium">{item.name}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- 轮播控制按钮 -->
          <button 
            id="prev-btn"
            class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/90 dark:bg-neutral-800/90 shadow-lg flex items-center justify-center text-neutral-700 dark:text-neutral-200 hover:bg-white dark:hover:bg-neutral-700 transition-all z-10"
            aria-label="上一张"
          >
            <ChevronLeft size={24} />
          </button>
          <button 
            id="next-btn"
            class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/90 dark:bg-neutral-800/90 shadow-lg flex items-center justify-center text-neutral-700 dark:text-neutral-200 hover:bg-white dark:hover:bg-neutral-700 transition-all z-10"
            aria-label="下一张"
          >
            <ChevronRight size={24} />
          </button>

          <!-- 轮播指示器 -->
          <div class="flex justify-center gap-2 mt-6" id="carousel-dots">
            {brandImages.map((_, index) => (
              <button 
                class="w-3 h-3 rounded-full bg-neutral-300 dark:bg-neutral-600 transition-all carousel-dot"
                data-index={index}
                aria-label={`跳转到第 ${index + 1} 张`}
              />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 返回作品集按钮 -->
    <section class="relative z-10 py-8 px-4 md:px-8 text-center">
      <div class="max-w-4xl mx-auto">
        <a 
          href="/works" 
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-yellow-400 via-lime-500 to-emerald-500 text-white font-medium shadow-lg shadow-lime-200/50 hover:shadow-xl hover:shadow-lime-200/70 transition-all duration-300 hover:-translate-y-1"
        >
          <ArrowLeft size={20} />
          <span>返回作品集</span>
        </a>
      </div>
    </section>

    <!-- 页脚 -->
    <footer class="relative z-10 py-12 px-4 md:px-8 text-center">
      <div class="max-w-4xl mx-auto">
        <div class="flex justify-center gap-2">
          <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
          <span class="w-3 h-3 rounded-full bg-lime-400"></span>
          <span class="w-3 h-3 rounded-full bg-emerald-400"></span>
        </div>
      </div>
    </footer>
  </div>
</PostLayout>

<script>
  // 轮播功能
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('carousel-track');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const dots = document.querySelectorAll('.carousel-dot');
    
    if (!track || !prevBtn || !nextBtn) return;
    
    const items = track.children;
    const totalItems = items.length;
    let currentIndex = 0;
    
    function updateCarousel() {
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
      
      // 更新指示器
      dots.forEach((dot, index) => {
        if (index === currentIndex) {
          dot.classList.add('bg-lime-500', 'scale-125');
          dot.classList.remove('bg-neutral-300', 'dark:bg-neutral-600');
        } else {
          dot.classList.remove('bg-lime-500', 'scale-125');
          dot.classList.add('bg-neutral-300', 'dark:bg-neutral-600');
        }
      });
    }
    
    function nextSlide() {
      currentIndex = (currentIndex + 1) % totalItems;
      updateCarousel();
    }
    
    function prevSlide() {
      currentIndex = (currentIndex - 1 + totalItems) % totalItems;
      updateCarousel();
    }
    
    // 按钮事件
    nextBtn.addEventListener('click', nextSlide);
    prevBtn.addEventListener('click', prevSlide);
    
    // 指示器点击事件
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        currentIndex = index;
        updateCarousel();
      });
    });
    
    // 自动播放
    let autoPlay = setInterval(nextSlide, 4000);
    
    // 鼠标悬停时暂停
    const carousel = document.getElementById('brand-carousel');
    carousel?.addEventListener('mouseenter', () => clearInterval(autoPlay));
    carousel?.addEventListener('mouseleave', () => {
      autoPlay = setInterval(nextSlide, 4000);
    });
    
    // 初始化
    updateCarousel();
  });
</script>

<style>
  /* 瀑布流优化 */
  .break-inside-avoid {
    break-inside: avoid;
  }

  /* 渐变文字动画 */
  @keyframes gradient-shift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  h1 {
    background-size: 200% 200%;
    animation: gradient-shift 5s ease infinite;
  }

  /* 背景色变量 */
  .bg-background {
    background-color: rgb(var(--background));
  }
</style>
