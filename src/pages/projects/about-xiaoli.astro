---
import PostLayout from "@/layouts/PostLayout.astro";
import { ArrowLeft, Cat, Sparkles, Heart, X, ZoomIn } from "@lucide/astro";

// 小狸图片数据
const xiaoliImages = [
  { id: 1, name: "伞", image: "/assets/projects/小狸/伞.webp" },
  { id: 2, name: "元宵", image: "/assets/projects/小狸/元宵.webp" },
  { id: 3, name: "几何体", image: "/assets/projects/小狸/几何体.webp" },
  { id: 4, name: "喝饮料", image: "/assets/projects/小狸/喝饮料.webp" },
  { id: 5, name: "夏日", image: "/assets/projects/小狸/夏日.webp" },
  { id: 6, name: "新年", image: "/assets/projects/小狸/新年.webp" },
  { id: 7, name: "春", image: "/assets/projects/小狸/春.webp" },
  { id: 8, name: "植物", image: "/assets/projects/小狸/植物.webp" },
  { id: 9, name: "海", image: "/assets/projects/小狸/海.webp" },
  { id: 10, name: "赶海", image: "/assets/projects/小狸/赶海.webp" },
  { id: 11, name: "雪地", image: "/assets/projects/小狸/雪地.webp" },
];

// 条漫数据
const tiaomanImages = [
  { id: 1, name: "条漫1", image: "/assets/projects/小狸/条漫1.webp" },
  { id: 2, name: "条漫2", image: "/assets/projects/小狸/条漫2.webp" },
];
---

<PostLayout
  title="关于小狸"
  description="可爱的半狸猫半人生物，了解更多关于小狸的故事！"
  keywords="小狸, 角色, 设计, 半狸猫半人"
>
  <div class="min-h-screen bg-background">
    <!-- 头部导航 -->
    <header class="relative z-10 py-6 px-4 md:px-8">
      <div class="max-w-7xl mx-auto">
        <a 
          href="/works" 
          class="inline-flex items-center gap-2 text-neutral-600 dark:text-neutral-400 hover:text-orange-500 transition-colors group"
        >
          <ArrowLeft size={20} class="group-hover:-translate-x-1 transition-transform" />
          <span class="font-medium">返回作品集</span>
        </a>
      </div>
    </header>

    <!-- 英雄区域 -->
    <section class="relative z-10 py-16 md:py-24 px-4 md:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <!-- 装饰图标 -->
        <div class="flex justify-center gap-4 mb-8">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-orange-400 to-amber-500 flex items-center justify-center shadow-lg shadow-orange-200/50 rotate-3 hover:rotate-6 transition-transform">
            <Cat class="text-white" size={28} />
          </div>
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-amber-400 to-yellow-500 flex items-center justify-center shadow-lg shadow-amber-200/50 -rotate-3 hover:-rotate-6 transition-transform">
            <Sparkles class="text-white" size={28} />
          </div>
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-yellow-400 to-orange-500 flex items-center justify-center shadow-lg shadow-yellow-200/50 rotate-3 hover:rotate-6 transition-transform">
            <Heart class="text-white" size={28} />
          </div>
        </div>

        <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-orange-500 via-amber-500 to-yellow-500 bg-clip-text text-transparent">
          关于小狸
        </h1>
        
        <div class="flex flex-wrap justify-center gap-3 mb-8">
          <span class="px-4 py-2 rounded-full bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 text-sm font-medium">角色</span>
          <span class="px-4 py-2 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 text-sm font-medium">设计</span>
        </div>

        <p class="text-xl md:text-2xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto leading-relaxed">
          可爱的半狸猫半人生物，了解更多关于小狸的故事！
        </p>
      </div>
    </section>

    <!-- 视频展示区 -->
    <section class="relative z-10 py-12 px-4 md:px-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-800 dark:text-neutral-200 mb-8 flex items-center gap-3">
          <span class="w-1 h-8 bg-gradient-to-b from-orange-400 to-amber-500 rounded-full"></span>
          小狸的视频
        </h2>
        
        <!-- Bilibili 视频播放器 -->
        <div class="relative w-full rounded-2xl overflow-hidden shadow-2xl bg-black aspect-video">
          <iframe 
            src="//player.bilibili.com/player.html?isOutside=true&aid=116192303913601&bvid=BV1TaNMzwE7P&cid=36546806179&p=1" 
            scrolling="no" 
            border="0" 
            frameborder="no" 
            framespacing="0" 
            allowfullscreen="true"
            class="absolute inset-0 w-full h-full"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- 条漫展示区 -->
    <section class="relative z-10 py-12 px-4 md:px-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-800 dark:text-neutral-200 mb-8 flex items-center gap-3">
          <span class="w-1 h-8 bg-gradient-to-b from-orange-400 to-amber-500 rounded-full"></span>
          小狸的条漫
        </h2>

        <!-- 条漫并排布局 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {tiaomanImages.map((item, index) => (
            <div 
              class="group relative overflow-hidden rounded-xl bg-white dark:bg-neutral-800 shadow-md hover:shadow-xl transition-all duration-500 cursor-pointer"
              data-aos="fade-up"
              data-aos-delay={index * 100}
              onclick={`openLightbox('${item.image}', '${item.name}')`}
            >
              <div class="relative overflow-hidden aspect-[3/4]">
                <img 
                  src={item.image} 
                  alt={item.name}
                  class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
                <!-- 点击提示 -->
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-300 flex items-center justify-center">
                  <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform scale-90 group-hover:scale-100">
                    <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
                      <ZoomIn class="text-neutral-800" size={20} />
                    </div>
                  </div>
                </div>
              </div>
              <!-- 标题 -->
              <div class="px-4 py-3 border-t border-neutral-100 dark:border-neutral-700">
                <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">{item.name}</h3>
                <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5">点击查看大图</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 瀑布流展示区 -->
    <section class="relative z-10 py-12 px-4 md:px-8">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-800 dark:text-neutral-200 mb-8 flex items-center gap-3">
          <span class="w-1 h-8 bg-gradient-to-b from-orange-400 to-amber-500 rounded-full"></span>
          小狸的画册
        </h2>

        <!-- 瀑布流网格 -->
        <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
          {xiaoliImages.map((item, index) => (
            <div 
              class="break-inside-avoid group relative overflow-hidden rounded-2xl bg-white dark:bg-neutral-800 shadow-sm hover:shadow-xl transition-all duration-500 cursor-pointer"
              data-aos="fade-up"
              data-aos-delay={index * 50}
              onclick={`openLightbox('${item.image}', '${item.name}')`}
            >
              <div class="relative overflow-hidden">
                <img 
                  src={item.image} 
                  alt={item.name}
                  class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
                <!-- 悬停遮罩 -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between">
                    <span class="inline-block px-3 py-1 rounded-full bg-white/90 text-neutral-800 text-sm font-medium">
                      {item.name}
                    </span>
                    <ZoomIn class="text-white" size={20} />
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 返回作品集按钮 -->
    <section class="relative z-10 py-12 px-4 md:px-8 text-center">
      <div class="max-w-4xl mx-auto">
        <a 
          href="/works" 
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-orange-400 via-amber-500 to-yellow-500 text-white font-medium shadow-lg shadow-orange-200/50 hover:shadow-xl hover:shadow-orange-200/70 transition-all duration-300 hover:-translate-y-1"
        >
          <ArrowLeft size={20} />
          <span>返回作品集</span>
        </a>
      </div>
    </section>

    <!-- 页脚 -->
    <footer class="relative z-10 py-12 px-4 md:px-8 text-center">
      <div class="max-w-4xl mx-auto">
        <div class="flex justify-center gap-2">
          <span class="w-3 h-3 rounded-full bg-orange-400"></span>
          <span class="w-3 h-3 rounded-full bg-amber-400"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
        </div>
      </div>
    </footer>
  </div>

  <!-- 大图查看器 (Lightbox) -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden bg-black/95 backdrop-blur-sm" onclick="closeLightbox()">
    <!-- 关闭按钮 -->
    <button 
      class="absolute top-4 right-4 z-50 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
      onclick="event.stopPropagation(); closeLightbox()"
    >
      <X class="text-white" size={24} />
    </button>
    
    <!-- 图片容器 -->
    <div class="absolute inset-0 flex items-center justify-center p-4 md:p-8" onclick="event.stopPropagation()">
      <div class="relative max-w-full max-h-full">
        <img 
          id="lightbox-image" 
          src="" 
          alt="" 
          class="max-w-full max-h-[90vh] w-auto h-auto object-contain rounded-lg shadow-2xl"
        />
        <!-- 图片标题 -->
        <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/60 to-transparent rounded-b-lg">
          <p id="lightbox-title" class="text-white text-center text-lg font-medium"></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Lightbox 脚本 -->
  <script is:inline>
    function openLightbox(imageSrc, title) {
      const lightbox = document.getElementById('lightbox');
      const lightboxImage = document.getElementById('lightbox-image');
      const lightboxTitle = document.getElementById('lightbox-title');
      
      lightboxImage.src = imageSrc;
      lightboxTitle.textContent = title;
      lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      const lightbox = document.getElementById('lightbox');
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // ESC 键关闭
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeLightbox();
      }
    });
  </script>
</PostLayout>

<style>
  /* 瀑布流优化 */
  .break-inside-avoid {
    break-inside: avoid;
  }

  /* 渐变文字动画 */
  @keyframes gradient-shift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  h1 {
    background-size: 200% 200%;
    animation: gradient-shift 5s ease infinite;
  }

  /* 背景色变量 */
  .bg-background {
    background-color: rgb(var(--background));
  }

  /* Lightbox 动画 */
  #lightbox {
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  #lightbox-image {
    animation: scaleIn 0.3s ease;
  }

  @keyframes scaleIn {
    from {
      transform: scale(0.9);
    }
    to {
      transform: scale(1);
    }
  }
</style>
