<!-- 3D 倾斜交互脚本 -->
<script>
(() => {
  // 获取所有倾斜图片
  const tiltImages = document.querySelectorAll('.tilt-image');
  
  tiltImages.forEach(img => {
    // 鼠标移动时的倾斜效果
    img.addEventListener('mousemove', (e) => {
      const rect = img.getBoundingClientRect();
      const imgWidth = rect.width;
      const imgHeight = rect.height;
      
      // 计算鼠标在图片内的相对位置（-1 到 1）
      const mouseX = e.clientX - rect.left;
      const mouseY = e.clientY - rect.top;
      
      // 转换为 -1 到 1 的范围
      const normalizeX = (mouseX / imgWidth) * 2 - 1;
      const normalizeY = (mouseY / imgHeight) * 2 - 1;
      
      // 计算旋转角度（最大 15 度）
      const rotateY = normalizeX * 15; // 左右翻转
      const rotateX = -normalizeY * 15; // 上下翻转
      
      // 应用 3D 变换
      img.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
    });
    
    // 鼠标离开时恢复原状
    img.addEventListener('mouseleave', () => {
      img.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
    });
    
    // 鼠标进入时设置过渡效果
    img.addEventListener('mouseenter', () => {
      img.style.transition = 'transform 0.2s ease-out';
    });
    
    // 鼠标移动时移除过渡效果（减少延迟）
    img.addEventListener('mousemove', () => {
      img.style.transition = 'none';
    });
  });
  
  // Knights Poker 3D 扑克牌 3x3 网格展开交互
  const pokerCards = document.querySelectorAll('.poker-card');
  const container = document.getElementById('poker-container');
  const hint = document.querySelector('.interactive-hint');
  if (pokerCards.length > 0 && container) {
    let isExpanded = false;
    
    // 计算 3x3 网格位置
    const getGridPosition = (index) => {
      const row = Math.floor(index / 3);
      const col = index % 3;
      
      // 每张牌间距：牌宽 210px + 间距 120px = 330px
      // 3x3 网格中心点为 (1, 1)
      const gap = 330;
      const offsetX = (col - 1) * gap;
      const offsetY = (row - 1) * gap;
      
      return { x: offsetX, y: offsetY };
    };
    
    // 呼吸动画
    let breathPhase = 0;
    const animateBreath = () => {
      if (!isExpanded && hint) {
        breathPhase += 0.03;
        const opacity = 0.4 + Math.sin(breathPhase) * 0.4; // 0.0 - 0.8
        const scale = 1 + Math.sin(breathPhase * 0.8) * 0.08; // 0.92 - 1.08
        
        hint.style.opacity = opacity.toString();
        hint.style.transform = `translateX(-50%) scale(${scale})`;
      }
      requestAnimationFrame(animateBreath);
    };
    animateBreath();
    
    // 点击容器展开/收起
    container.addEventListener('click', () => {
      isExpanded = !isExpanded;
      
      // 隐藏提示文本
      if (hint) {
        hint.style.opacity = '0';
      }
      
      if (isExpanded) {
        // 展开到 3x3 网格 - 依次排布
        pokerCards.forEach((card, index) => {
          const pos = getGridPosition(index);
          
          // 每张牌依次延迟 100ms 开始移动
          setTimeout(() => {
            card.style.transition = 'transform 0.5s cubic-bezier(0.23, 1, 0.32, 1), z-index 0.3s';
            card.style.transform = `translate(${pos.x}px, ${pos.y}px) rotateY(180deg)`;
            card.style.zIndex = '10';
          }, index * 100);
        });
      } else {
        // 收起到中心堆叠 - 依次收回
        pokerCards.forEach((card, index) => {
          // 从最后一张牌开始依次收回
          const reverseIndex = pokerCards.length - 1 - index;
          
          setTimeout(() => {
            card.style.transition = 'transform 0.5s cubic-bezier(0.23, 1, 0.32, 1), z-index 0.3s';
            card.style.transform = 'translate(0px, 0px) rotateY(0deg)';
            card.style.zIndex = reverseIndex;
          }, index * 80);
        });
        
        // 显示提示文本
        setTimeout(() => {
          if (hint) {
            hint.style.opacity = '1';
          }
        }, pokerCards.length * 80 + 300);
      }
    });
    
    // 阶段 B：悬停抽牌交互
    pokerCards.forEach((card, index) => {
      card.addEventListener('mouseenter', () => {
        // 悬停时置顶并抽出
        card.style.zIndex = '50';
        card.style.transition = 'transform 0.3s cubic-bezier(0.23, 1, 0.32, 1), z-index 0.1s';
        
        // 在原有角度基础上向外抽出
        const currentTransform = card.style.transform;
        const rotateYMatch = currentTransform.match(/rotateY\(([^)]+)\)/);
        const rotateY = rotateYMatch ? rotateYMatch[1] : '0deg';
        
        const translateMatch = currentTransform.match(/translate\(([^)]+)\)/);
        const translate = translateMatch ? translateMatch[1] : '0px, 0px';
        
        card.style.transform = `translate(${translate}) rotateY(${rotateY}) scale(1.15)`;
      });
      
      card.addEventListener('mouseleave', () => {
        // 恢复原始位置
        card.style.zIndex = isExpanded ? '10' : index;
        card.style.transition = 'transform 0.5s cubic-bezier(0.23, 1, 0.32, 1), z-index 0.3s';
        
        if (isExpanded) {
          const pos = getGridPosition(index);
          card.style.transform = `translate(${pos.x}px, ${pos.y}px) rotateY(180deg)`;
        } else {
          card.style.transform = 'translate(0px, 0px) rotateY(0deg)';
        }
      });
    });
  }
})();
</script>

<!-- 明信片轮播交互脚本 -->
<script>
	function initCarousel() {
		const slides = document.querySelectorAll('.carousel-slide');
		const dots = document.querySelectorAll('.carousel-dot');
		
		if(!slides.length || !dots.length) return;

		dots.forEach((dot, index) => {
			dot.addEventListener('click', () => {
				// 更新所有 slide
				slides.forEach((slide, i) => {
					if (i === index) {
						slide.classList.remove('opacity-0', 'z-0');
						slide.classList.add('opacity-100', 'z-10');
					} else {
						slide.classList.remove('opacity-100', 'z-10');
						slide.classList.add('opacity-0', 'z-0');
					}
				});
				
				// 更新所有 dot 的样式
				dots.forEach((d, i) => {
					if (i === index) {
						d.classList.replace('bg-gray-300', 'bg-blue-500');
						d.classList.add('scale-110');
					} else {
						d.classList.replace('bg-blue-500', 'bg-gray-300');
						d.classList.remove('scale-110');
					}
				});
			});
		});
	}

	// 确保在 Astro 页面切换时也能触发
	document.addEventListener('astro:page-load', initCarousel);
	document.addEventListener('DOMContentLoaded', initCarousel);
</script>

