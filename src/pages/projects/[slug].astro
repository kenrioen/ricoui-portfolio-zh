---
import { ArrowLeft } from "@lucide/astro";
import PostLayout from "@/layouts/PostLayout.astro";
import PageHeader from "@/components/elements/PageHeader.astro";
import SeparatorLine from "@/components/elements/SeparatorLine.astro";
import works from "@/collections/works.json";

export async function getStaticPaths() {
  return works.filter(work => work.slug).map(work => ({
    params: { slug: work.slug }
  }));
}

const { slug } = Astro.params;
const work = works.find(w => w.slug === slug);

if (!work) {
  return Astro.redirect("/works");
}
---

<PostLayout
	title={work.name}
	description={work.content?.summary || work.description || ""}
	keywords={work.tags?.join(", ") || ""}
>
	<div class="work article">
		<main class="work-wrapper">
			<!-- 返回按钮 -->
			<div class="site-container m-auto mb-6">
				<a
					href="/works"
					class="inline-flex items-center gap-2 text-neutral-600 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-300 mb-8"
				>
					<ArrowLeft size={16} />
					<span>返回作品集</span>
				</a>

				<PageHeader
					title={work.name}
					tags={work.tags}
					className="mb-6 md:mb-8"
				/>
			</div>

			<div class="site-container m-auto">
				<SeparatorLine />
			</div>

			{work.heroImage && (
				<div class="site-container mx-auto mt-8">
					<div class="overflow-hidden rounded-2xl">
						<img
							src={work.heroImage}
							alt={work.name}
							class="w-full h-auto object-cover"
							loading="lazy"
						/>
					</div>
				</div>
			)}

			<!-- 项目详情区域 -->
			<section class="article-content">
				<div class="site-container mx-auto my-8 md:my-16">
					
					<!-- 1. 项目介绍区 (Design Statement) - 左右两栏不对称布局 -->
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-16">
						<!-- 左侧：项目元数据 (1/3) -->
						<div class="md:col-span-1 space-y-6">
							<div>
								<h3 class="text-sm font-semibold text-neutral-500 dark:text-neutral-400 uppercase tracking-wider mb-2">
									项目名称
								</h3>
								<p class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">
									{work.name}
								</p>
							</div>
							
							<div>
								<h3 class="text-sm font-semibold text-neutral-500 dark:text-neutral-400 uppercase tracking-wider mb-2">
									类别
								</h3>
								<p class="text-lg text-neutral-800 dark:text-neutral-200">
									音乐专辑 / 视觉传达 / 产品落地
								</p>
							</div>
							
							{work.tags && work.tags.length > 0 && (
								<div>
									<h3 class={`text-sm font-semibold uppercase tracking-wider mb-3 ${work.slug === 'the-botanists-lag' ? 'text-green-500' : 'text-neutral-500 dark:text-neutral-400'}`}>
										标签
									</h3>
									<div class="flex flex-wrap gap-2">
										{work.tags.map((tag) => (
											<span class={`px-3 py-1 text-sm rounded-full ${work.slug === 'the-botanists-lag' ? 'bg-green-900/30 text-green-400 border border-green-500/50' : 'bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300'}`}>
												{tag}
											</span>
										))}
									</div>
								</div>
							)}
						</div>
						
						<!-- 右侧：核心理念与说明 (2/3) - 带逐段淡入动效 -->
						<div class="md:col-span-2 space-y-6">
							{work.slug === 'the-botanists-lag' ? (
								<!-- 观山杯音乐专辑专用布局 -->
								<div 
									class="p-4 md:p-5 rounded-xl"
									data-aos="fade-up"
									data-aos-duration="800"
									data-aos-delay="100"
								>
									<h3 class="text-sm font-semibold text-neutral-600 dark:text-neutral-400 mb-2.5 flex items-center gap-2">
										<span class="w-1 h-4 bg-green-500 rounded-full"></span>
										关于专辑
									</h3>
									<p class="text-sm md:text-base text-neutral-700 dark:text-neutral-300 leading-snug">
										设计动机是受友人委托，为他新作的专辑设计视觉全案。这算是我第一次做有关实体专辑的设计，反反复复修改多次很是紧张，因为我相信这对于我的友人来说也是很重要的专辑，其中真挚的感情听者必会有所体会，最后这张专辑也是顺利落地，并取得了不错的销售额。
										后面为了能给友人这张专辑更好的呈现形式，我利用 godot 引擎定制了起专属的交互式 cd 播放机
									</p>
								</div>
							) : work.slug === 'knights-poker' ? (
								<!-- Knights Poker 扑克牌专用布局 -->
								<div 
									class="p-4 md:p-5 rounded-xl bg-[#fcfbf9] dark:bg-neutral-900"
									data-aos="fade-up"
									data-aos-duration="800"
									data-aos-delay="100"
								>
									
								</div>
							) : (
								<!-- 林间鸟原有布局 -->
								<>
									<div 
										class="p-4 md:p-5 bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-950/20 dark:to-indigo-950/20 rounded-xl border border-blue-100 dark:border-blue-800/30"
										data-aos="fade-up"
										data-aos-duration="800"
										data-aos-delay="100"
									>
										<h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2.5 flex items-center gap-2">
											<span class="w-1 h-4 bg-blue-500 rounded-full"></span>
											设计动机
										</h3>
										<p class="text-sm md:text-base font-medium text-blue-800 dark:text-blue-200 leading-snug">
											"北林拥有得天独厚的自然生态，但我发现许多日常栖息在校园里的鸟类对同学们来说却形同'熟悉的陌生人'。本项目旨在通过视觉干预，将传统的生物科普转化为生动亲切的校园文化符号。"
										</p>
									</div>
									
									<div 
										class="space-y-4"
										data-aos="fade-up"
										data-aos-duration="800"
										data-aos-delay="200"
									>
										<h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 flex items-center gap-2">
											<span class="w-1 h-6 bg-indigo-500 rounded-full"></span>
											视觉转化与落地
										</h3>
										<p class="text-neutral-700 dark:text-neutral-300 leading-relaxed text-lg">
											设计提取了夜鹭、灰喜鹊、乌鸫等校园常见鸟类，摒弃了传统科普图鉴的刻板印象，采用现代扁平化与几何切割风格重构形体特征。在明信片延展中，进一步将鸟类与学研大厦、博物馆等标志性建筑及黄刺玫、银杏等特色植物进行视觉拼贴与重组。
										</p>
										<p class="text-neutral-700 dark:text-neutral-300 leading-relaxed text-lg">
											有别于停留在屏幕上的概念稿，全套视觉最终投入实体打样，落地为纸质贴纸、滴胶贴纸与明信片等实体周边，并在北林校友会及绿色产融嘉年华等线下活动中完成了真实的销售转化与市场验证。
										</p>
									</div>
								</>
							)}
						</div>
					</div>

					{work.slug === 'the-botanists-lag' ? (
						<!-- 观山杯沉浸式暗黑主题 -->
						<div class="bg-black text-zinc-100 -mx-4 px-4 md:-mx-8 md:px-8 py-12">
							


							<!-- Godot 交互播放器嵌入 -->
							<div class="mb-16">
								<h2 
									class="text-2xl md:text-3xl font-bold mb-8 text-center"
									style="color: #22c55e;"
									data-aos="fade-up"
									data-aos-duration="800"
								>
									交互式音乐播放器
								</h2>
								
								<div 
									class="w-full max-w-5xl mx-auto aspect-video rounded-xl overflow-hidden"
									data-aos="fade-up"
									data-aos-duration="800"
									data-aos-delay="100"
								>
									<iframe 
										src="/assets/projects/botanist-player/index.html"
										title="观山杯 - Interactive Music Player"
										class="w-full h-full border-0"
										loading="lazy"
										allow="autoplay; fullscreen"
									></iframe>
								</div>
							</div>

							<!-- 曲目列表 + 封面 -->
							<div class="mb-16">
								<h2 
									class="text-2xl md:text-3xl font-bold mb-8 text-center"
									style="color: #22c55e;"
									data-aos="fade-up"
									data-aos-duration="800"
								>
									曲目列表
								</h2>
								
								<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-5xl mx-auto items-start">
									<!-- 左侧：封面 -->
									<div class="lg:col-span-1" data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
										<img
											src="/assets/projects/botanist-lag/cover.png"
											alt="观山杯专辑封面"
											class="w-full aspect-square object-cover rounded-lg shadow-lg shadow-green-900/20"
											loading="lazy"
										/>
										<div class="mt-4 text-center">
											<h3 class="text-lg font-bold" style="color: #22c55e;">观山杯</h3>
											<p class="text-sm text-zinc-500 mt-1">2025 </p>
										</div>
									</div>
									
									<!-- 右侧：曲目列表 -->
									<div class="lg:col-span-2 space-y-3 pt-[45px]" data-aos="fade-up" data-aos-duration="800" data-aos-delay="200">
										{[
											{ track: "01", title: "观山杯", time: "3:42" },
											{ track: "02", title: "忠山", time: "4:15" },
											{ track: "03", title: "不高山", time: "3:58" },
											{ track: "04", title: "假山", time: "4:22" },
											{ track: "05", title: "宝藏山", time: "5:02" }
										].map((item, index) => (
											<div class="flex items-center justify-between p-4 rounded-lg bg-zinc-900/50 border border-zinc-800 hover:border-green-500/50 transition-colors duration-300">
												<div class="flex items-center gap-4">
													<span class="text-sm font-medium text-zinc-500 w-6">{item.track}</span>
													<span class="text-base font-medium text-zinc-200">{item.title}</span>
												</div>
												<span class="text-sm text-zinc-500">{item.time}</span>
											</div>
										))}
									</div>
								</div>
							</div>

							<!-- 实体装帧设计 -->
							<div class="mb-16">
								<h2 
									class="text-2xl md:text-3xl font-bold mb-8 text-center"
									style="color: #22c55e;"
									data-aos="fade-up"
									data-aos-duration="800"
								>
									实体装帧设计
								</h2>
								
								<!-- 顶部：观山杯效果图 -->
								<div class="max-w-5xl mx-auto mb-8" data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
									<img
										src="/assets/projects/botanist-lag/mockup.png"
										alt="观山杯效果图 - 主视觉"
										class="w-full h-auto rounded-lg shadow-2xl shadow-green-900/10"
										loading="lazy"
									/>
								</div>
								
								<!-- 三列：歌词本内页 -->
								<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto" data-aos="fade-up" data-aos-duration="800" data-aos-delay="200">
									{[
										{ src: "/assets/projects/botanist-lag/lyric-1.png", alt: "歌词本内页 1" },
										{ src: "/assets/projects/botanist-lag/lyric-2.png", alt: "歌词本内页 2" },
										{ src: "/assets/projects/botanist-lag/lyric-3.png", alt: "歌词本内页 3" }
									].map((item, index) => (
										<div class="group relative overflow-hidden rounded-lg transition-all duration-300 hover:-translate-y-2">
											<div class="absolute inset-0 bg-gradient-to-t from-green-500/0 to-green-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
											<img
												src={item.src}
												alt={item.alt}
												class="w-full h-auto object-cover"
												loading="lazy"
											/>
										</div>
									))}
								</div>
							</div>

							
						</div>
					) : work.slug === 'knights-poker' ? (
						<!-- Knights Poker 扑克牌专用布局 -->
						<div class="bg-[#fcfbf9] dark:bg-neutral-950 -mx-4 px-4 md:-mx-8 md:px-8 py-16">
							
							<!-- 头部：设计动机与视觉转化 -->
							<div class="max-w-4xl mx-auto mb-16">
								<!-- 设计动机 -->
								<div 
									class="p-6 md:p-8 rounded-xl mb-16"
									data-aos="fade-up"
									data-aos-duration="800"
									data-aos-delay="100"
								>
									<h3 class="text-base md:text-lg font-semibold text-neutral-600 dark:text-neutral-400 mb-4 flex items-center gap-2">
										<span class="w-1.5 h-5 bg-amber-500 rounded-full"></span>
										设计动机
									</h3>
									<p class="text-base md:text-lg text-neutral-700 dark:text-neutral-300 leading-relaxed">
										受甘肃博物馆《钢铁与荣耀》特展启发，我试图探讨"骑士精神"在现代社会的视觉延续。项目将中世纪骑士与现代犬类建立情感映射，以扑克牌为载体，打造一套兼顾历史厚重感与现代情感共鸣的文创周边。
									</p>
								</div>
								
								<!-- 视觉转化与实体装帧 -->
								<div 
									class="p-6 md:p-8 rounded-xl"
									data-aos="fade-up"
									data-aos-duration="800"
									data-aos-delay="200"
								>
									<h3 class="text-base md:text-lg font-semibold text-neutral-600 dark:text-neutral-400 mb-4 flex items-center gap-2">
										<span class="w-1.5 h-5 bg-amber-500 rounded-full"></span>
										视觉转化与实体装帧
									</h3>
									<p class="text-base md:text-lg text-neutral-700 dark:text-neutral-300 leading-relaxed">
										摒弃了传统的宫廷人头牌，J、Q、K 创新性地采用"骑士与犬"上下镜像的二分构图（如边牧代表智慧，德牧代表勇敢）。数字牌则提取了展览中的真实兵器藏品。全套视觉采用红黑双色与单色蚀刻版画风格，最终落地为实体扑克与定制包装，呈现了一场跨越时空的牌桌对局。
									</p>
								</div>
							</div>
							
							<!-- 3D 扑克牌扇形展台 -->
							<div class="h-[1200px] w-full relative flex justify-center items-center overflow-hidden mb-16" id="poker-container">
								<!-- 9 张扑克牌 -->
								{[0, 1, 2, 3, 4, 5, 6, 7, 8].map((index) => (
									<div 
										class={`poker-card absolute w-[210px] h-[315px] cursor-pointer transition-all duration-[2000] ease-out`}
										data-index={index}
										style={{
											transform: 'rotateY(0deg)',
											transformStyle: 'preserve-3d',
											transformOrigin: 'center center',
											left: '50%',
											top: '50%',
											marginLeft: '-105px',
											marginTop: '-157.5px'
										}}
									>
										<!-- 牌面（正面） -->
										<div 
											class="absolute inset-0 rounded-xl shadow-2xl"
											style={{
												backfaceVisibility: 'hidden',
												transform: 'rotateY(180deg)'
											}}
										>
											<img
												src={`/assets/projects/knights-poker/card-front-${index + 1}.png`}
												alt={`扑克牌正面 ${index + 1}`}
												class="w-full h-full object-cover rounded-xl"
												loading="lazy"
											/>
										</div>
										
										<!-- 牌背（背面） -->
										<div 
											class="absolute inset-0 rounded-xl shadow-2xl"
											style={{
												backfaceVisibility: 'hidden',
												transform: 'rotateY(0deg)'
											}}
										>
											<img
												src="/assets/projects/knights-poker/card-back.png"
												alt="扑克牌背面"
												class="w-full h-full object-cover rounded-xl"
												loading="lazy"
											/>
										</div>
									</div>
								))}
								
								<!-- 互动提示文本 -->
								<div 
									class="interactive-hint absolute bottom-[20%] left-1/2 text-neutral-500 dark:text-neutral-400 text-sm md:text-base tracking-widest"
									style={{
										opacity: '1',
										transition: 'opacity 0.5s ease',
										transform: 'translateX(-50%)'
									}}
								>
									点击互动牌组
								</div>
							</div>
							
							<!-- 实体装帧：2x2 Mockups Grid -->
							<div class="max-w-5xl mx-auto mb-24" data-aos="fade-up" data-aos-duration="800">
								<h2 class="text-xl md:text-2xl font-bold text-neutral-800 dark:text-neutral-200 mb-8 text-center">
									实体装帧：跨越时空的对局
								</h2>
								
								<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12 mb-24">
									<!-- Mockup 1 -->
									<div class="overflow-hidden rounded-xl shadow-lg shadow-black/5 transition-transform hover:-translate-y-1 hover:shadow-2xl">
										<img
											src="/assets/projects/knights-poker/mockup-1.png"
											alt="Knights Poker 实体效果图 1"
											class="w-full h-auto object-cover aspect-[4/3]"
											loading="lazy"
										/>
									</div>
									
									<!-- Mockup 2 -->
									<div class="overflow-hidden rounded-xl shadow-lg shadow-black/5 transition-transform hover:-translate-y-1 hover:shadow-2xl">
										<img
											src="/assets/projects/knights-poker/mockup-2.png"
											alt="Knights Poker 实体效果图 2"
											class="w-full h-auto object-cover aspect-[4/3]"
											loading="lazy"
										/>
									</div>
									
									<!-- Mockup 3 -->
									<div class="overflow-hidden rounded-xl shadow-lg shadow-black/5 transition-transform hover:-translate-y-1 hover:shadow-2xl">
										<img
											src="/assets/projects/knights-poker/mockup-3.png"
											alt="Knights Poker 实体效果图 3"
											class="w-full h-auto object-cover aspect-[4/3]"
											loading="lazy"
										/>
									</div>
									
									<!-- Mockup 4 -->
									<div class="overflow-hidden rounded-xl shadow-lg shadow-black/5 transition-transform hover:-translate-y-1 hover:shadow-2xl">
										<img
											src="/assets/projects/knights-poker/mockup-4.png"
											alt="Knights Poker 实体效果图 4"
											class="w-full h-auto object-cover aspect-[4/3]"
											loading="lazy"
										/>
									</div>
								</div>
							</div>

							<!-- 全套牌面展示 -->
							<div class="max-w-6xl mx-auto" data-aos="fade-up" data-aos-duration="800">
								<img
									src="/assets/projects/knights-poker/full-deck.png"
									alt="Knights Poker 全套牌面展示"
									class="w-full h-auto block rounded-lg shadow-xl"
									loading="lazy"
								/>
							</div>
						</div>
					) : (
					<div class="mb-16">
						<h2 
							class="text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-12 text-center"
							data-aos="fade-up"
							data-aos-duration="800"
						>
							纸质与滴胶贴纸
						</h2>
						
						<!-- 单列竖排布局，移除所有背景色和边框 -->
						<div class="flex flex-col items-center gap-24">
							<div 
								class="tilt-container w-full max-w-4xl"
								data-aos="fade-up"
								data-aos-duration="800"
								data-aos-delay="100"
							>
								<img
									src="/assets/projects/bird-paper.png"
									alt="林间鸟 - 纸质贴纸效果"
									class="tilt-image w-full h-auto object-contain cursor-pointer"
									loading="lazy"
								/>
							</div>
							
							<div 
								class="tilt-container w-full max-w-4xl"
								data-aos="fade-up"
								data-aos-duration="800"
								data-aos-delay="200"
							>
								<img
									src="/assets/projects/bird-resin.png"
									alt="林间鸟 - 滴胶贴纸效果"
									class="tilt-image w-full h-auto object-contain cursor-pointer"
									loading="lazy"
								/>
							</div>
						</div>
					</div>

