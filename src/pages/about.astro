---
import {
	ArrowUpRight,
	BookOpen,
	Mail,
	Palette,
	PenTool,
	Users,
} from "@lucide/astro";
import Button from "@/components/ui/Button.astro";
import Matter from "@/components/ui/Matter.astro";
import Layout from "@/layouts/Layout.astro";
import Toc from "@/components/widgets/Toc.astro";

// Manually define page table of contents structure
const headings = [
  { depth: 2, slug: "about-me", text: "关于我" },
  { depth: 2, slug: "expertise", text: "专业能力" },
  { depth: 2, slug: "tool-stack", text: "技术栈" },
  { depth: 2, slug: "lets-connect", text: "联系我" },
];

const filtered = headings.filter(h => h.depth <= 3);

---

<Layout title="关于我">
  <!-- Mobile TOC -->
  <div class="block lg:hidden px-7 pt-6">
    <Toc headings={filtered} />
  </div>

  <!-- Main container -->
  <div class="relative site-container  mx-auto my-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 xl:gap-16">
      <!-- Left TOC - Fixed on desktop -->
      <aside class="relative hidden lg:block lg:w-40 xl:w-50 flex-shrink-0">
          <div class="toc-sticky-wrapper">
            <Toc headings={filtered} />
          </div>
      </aside>

      <!-- Right main content - Adaptive width -->
      <main class="relative flex-1 min-w-0 w-full lg:max-w-none">
        <div
          class="w-full"
          data-aos="fade-up-xs"
          data-aos-duration="500"
          data-aos-once="true"
        >
            <h2
              id="about-me"
              class="text-2xl  tracking-tight  sm:text-3xl lg:text-4xl"
            >
             关于我
            </h2>
            <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-4 mb-8"></div>
      </div>

        <div
          class="flex items-center gap-3 mb-6"
          data-aos="fade-up-xs"
          data-aos-delay="100"
          data-aos-duration="500"
          data-aos-once="true"
        >
            <img src="/assets/avatar.webp" alt="黄仕倩" class="w-14 h-14 rounded-full">
            <div class="flex items-center gap-3">
              <span class="text-[24px] text-neutral-700 dark:text-neutral-100">黄仕倩</span>
            </div>
        </div>

        <div
          class="text-3xl mt-2 mb-2  italic text-left text-primary-strong dark:text-primary-light font-special"
          data-aos="fade-up-xs"
          data-aos-delay="200"
          data-aos-duration="500"
          data-aos-once="true"
        >"(Bringing cross-media concepts to life.)"</div>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-4 mb-8"></div>


        <p
          class="text-xl font-medium text-left text-neutral-800 dark:text-neutral-100"
          data-aos="fade-up-xs"
          data-aos-delay="100"
          data-aos-duration="500"
          data-aos-once="true"
        >
          我是一名跨媒介视觉设计师与内容企划策划。
        </p>
        <p
          class="text-neutral-700 pb-4 pt-4 leading-[1.8] dark:text-neutral-200"
          data-aos="fade-up-xs"
          data-aos-delay="200"
          data-aos-duration="500"
          data-aos-once="true"
        >
          我是一名"不仅画图，更重落地"的设计师，热衷于构建完整的视觉与概念世界。拥有扎实的视觉传达经验，目前专注于品牌视觉（VI 系统、导视系统）、出版物设计（书籍装帧），以及跨文化、跨媒介的内容创作与商业探索。

        </p>
        <p
          class="text-neutral-700 pb-4 pt-4 leading-[1.8] dark:text-neutral-200"
          data-aos="fade-up-xs"
          data-aos-delay="300"
          data-aos-duration="500"
          data-aos-once="true"
        >
          <strong> 🏷️ 我的个人标签： </strong> <br/>
          👩🏻‍🎨 <strong>视觉设计师</strong>，深耕品牌 VI 手册构建、线下空间导视系统及概念书籍设计。<br/>
          🤹🏻‍♀️ <strong>跨界创作者</strong>，将音乐感知、概念企划与视觉深度结合，包揽从海外嘉年华主视觉到独立音乐实体专辑的设计。<br/>
          💡 <strong>项目操盘手</strong>，热衷全链路执行，主导过文创 IP 从前期调研、0 到 1 孵化，再到线下展会宣发与销售的市场闭环。
       </p>

        <p
          class="text-neutral-700  leading-[1.8] dark:text-neutral-200"
          data-aos="fade-up-xs"
          data-aos-delay="400"
          data-aos-duration="500"
          data-aos-once="true"
        >
          作为一个设计师，"让概念落地"一直是我最大的驱动力。我不希望设计只局限于屏幕里的飞机稿，我喜欢把有趣的想法变成实实在在、能够被触摸和体验的项目。无论是统筹线下 IP 的落地售卖、把控独立音乐专辑下厂印刷的工艺质感，还是打磨严谨的 VI 手册与导视系统，这种将抽象审美转化为商业价值与受众共鸣的成就感，是单纯的排版无法满足的。我深信，多元的跨界触角与扎实的设计执行力相结合，能创造出更具生命力和商业潜力的视觉体验。
        </p>


        <div
          class="mt-8 mb-16 flex item-center justify-start gap-3"
          data-aos="fade-up-xs"
          data-aos-delay="500"
          data-aos-duration="500"
          data-aos-once="true"
        >
              <Button url="mailto:kenrioen@gmail.com" > <Mail  size={16} />  kenrioen@gmail.com</Button>
              <Button url="/resume.pdf" target="_blank" type="fill"> 简历 <ArrowUpRight  size={16} /> </Button>
        </div>



        <div class="w-full border-b-1 border-dashed border-b-neutral-200 dark:border-b-neutral-700 mt-4 mb-8"></div>
          <section>
              <h2
                id="expertise"
                class="mt-8 mb-2 text-[28px] text-neutral-800  dark:text-neutral-200"
                data-aos="fade-up-xs"
                data-aos-duration="500"
                data-aos-once="true"
              >专业能力</h2>
              <div
                class="list flex flex-wrap gap-3 mt-4 mb-12 w-full items-center justify-start"
                data-aos="fade-up-xs"
                data-aos-delay="100"
                data-aos-duration="600"
                data-aos-once="true"
              >
                <!-- 品牌视觉 (VI & Branding) -->
                <div class="item flex justify-start items-start flex-grow-0 flex-shrink-0 overflow-hidden gap-2 px-5 py-4 rounded-xl  bg-gradient-to-b from-[#f7f8f0] to-[#f1f2f9]  dark:from-gray-900 dark:to-gray-800 dark:text-neutral-200 ">
                  <div class="flex justify-center items-center flex-grow-0 flex-shrink-0 gap-2">
                    <Palette size={22} />
                    <div class="flex-grow-0 flex-shrink-0 text-base font-medium text-left text-neutral-700 dark:text-neutral-200">
                      品牌视觉 (VI & Branding)
                    </div>
                  </div>
                </div>
                <!-- 书籍装帧 (Editorial Design) -->
                <div class="item flex justify-start items-start flex-grow-0 flex-shrink-0 overflow-hidden gap-2 px-5 py-4  rounded-xl  bg-gradient-to-b from-[#f7f8f0] to-[#f1f2f9]  dark:from-gray-900 dark:to-gray-800">
                  <div class="flex justify-center items-center flex-grow-0 flex-shrink-0 gap-2">
                    <BookOpen size={22} />
                    <div class="flex-grow-0 flex-shrink-0 text-base font-medium text-left text-neutral-700 dark:text-neutral-200">
                      书籍装帧 (Editorial Design)
                    </div>
                  </div>
                </div>
                <!-- 跨媒介企划 (Content Planning) -->
                <div class="item flex justify-start items-start flex-grow-0 flex-shrink-0 overflow-hidden gap-2 px-5 py-4  rounded-xl  bg-gradient-to-b from-[#f7f8f0] to-[#f1f2f9]  dark:from-gray-900 dark:to-gray-800">
                  <div class="flex justify-center items-center flex-grow-0 flex-shrink-0 gap-2">
                    <PenTool size={22} />
                    <div class="flex-grow-0 flex-shrink-0 text-base font-medium text-left text-neutral-700 dark:text-neutral-200">
                      跨媒介企划 (Content Planning)
                    </div>
                  </div>
                </div>
                <!-- 多媒体与视觉 (Multimedia) -->
                <div class="item flex justify-start items-start flex-grow-0 flex-shrink-0 overflow-hidden gap-2 px-5 py-4  rounded-xl  bg-gradient-to-b from-[#f7f8f0] to-[#f1f2f9]  dark:from-gray-900 dark:to-gray-800">
                  <div class="flex justify-center items-center flex-grow-0 flex-shrink-0 gap-2">
                    <Users size={22} />
                    <div class="flex-grow-0 flex-shrink-0 text-base font-medium text-left text-neutral-700 dark:text-neutral-200">
                      多媒体与视觉 (Multimedia)
                    </div>
                  </div>
                </div>
                <!-- UI/UX 体验设计 -->
                <div class="item flex justify-start items-start flex-grow-0 flex-shrink-0 overflow-hidden gap-2 px-5 py-4  rounded-xl  bg-gradient-to-b from-[#f7f8f0] to-[#f1f2f9]  dark:from-gray-900 dark:to-gray-800">
                  <div class="flex justify-center items-center flex-grow-0 flex-shrink-0 gap-2">
                    <Palette size={22} />
                    <div class="flex-grow-0 flex-shrink-0 text-base font-medium text-left text-neutral-700 dark:text-neutral-200">
                      UI/UX 体验设计
                    </div>
                  </div>
                </div>
              </div>
          </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-4 mb-8"></div>

        <section>
          <h2
            id="tool-stack"
            class="mt-12 mb-4 text-[28px] text-neutral-800  dark:text-neutral-200 "
            data-aos="fade-up-xs"
            data-aos-duration="500"
            data-aos-once="true"
          >技术栈</h2>
          <div
            class="tool-stack-box relative bg-white border-accent/25 dark:bg-gray-900 rounded-xl overflow-hidden w-full h-[500px]"
            data-aos="fade-up-sm"
            data-aos-delay="100"
            data-aos-duration="600"
            data-aos-once="true"
          >
              <Matter />
              <!-- Fallback content if Matter.js doesn't load -->
              <div class="absolute inset-0 flex items-center justify-center text-white opacity-50">
              </div>
          </div>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-12 mb-12"></div>

      <section>
        <h2
          id="lets-connect"
          class="mt-12 mb-4 text-[28px] text-neutral-800  dark:text-neutral-200 "
          data-aos="fade-up-xs"
          data-aos-duration="500"
          data-aos-once="true"
        >联系我</h2>
        <p
          class="text-sm leading-6 text-neutral-700 dark:text-neutral-300"
          data-aos="fade-up-xs"
          data-aos-delay="100"
          data-aos-duration="500"
          data-aos-once="true"
        >
          如果你有兴趣和我合作或交流，请通过邮件或电话联系我。

          邮箱：kenrioen@gmail.com 
          电话：13331003647
        </p>
      </section>
      </main>
    </div>
  </div>
</Layout>

<style>
.toc-sticky-wrapper {
  position: sticky;
  top: 8rem;
}
</style>
