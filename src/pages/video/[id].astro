---
import Layout from "@/layouts/Layout.astro";
import { videos } from "@/data/videos";

export function getStaticPaths() {
  return videos.map((video) => ({
    params: { id: video.id },
    props: { video },
  }));
}

const { video } = Astro.props;

const pageTitle = `${video.title} - 视频作品`;
---

<Layout
  title={pageTitle}
  description={video.description}
  keywords={`${video.tags.join(', ')}, 视频作品，动态设计`}
>
  <div class="site-container py-16 md:py-20">
    <!-- 返回按钮 -->
    <div class="mb-8">
      <a
        href="/video"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 hover:bg-primary/10 hover:text-primary dark:hover:bg-primary/20 transition-colors duration-200 font-medium"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        返回视频主页
      </a>
    </div>

    <!-- 视频详情布局 -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <!-- 左侧：视频播放器 -->
      <div class="lg:col-span-8">
        <div class="sticky top-24">
          <!-- 原生 iframe 容器 - 响应式适配 -->
          <div class="w-full aspect-video rounded-xl overflow-hidden shadow-lg [&>iframe]:w-full [&>iframe]:h-full" set:html={video.iframeCode}></div>
        </div>
      </div>

      <!-- 右侧：视频信息 -->
      <div class="lg:col-span-4">
        <div class="space-y-6">
          <!-- 标题 -->
          <h1 class="text-3xl md:text-4xl font-bold text-neutral-800 dark:text-white">
            {video.title}
          </h1>

          <!-- 标签 -->
          <div class="flex flex-wrap gap-2">
            {video.tags.map((tag) => (
              <span class="px-4 py-2 text-sm font-medium rounded-full bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light">
                {tag}
              </span>
            ))}
          </div>

          <!-- 描述 -->
          <div class="prose prose-neutral dark:prose-invert max-w-none">
            <div class="text-neutral-700 dark:text-neutral-300 leading-relaxed space-y-4">
              <p>{video.description}</p>
            </div>
          </div>

          <!-- 分享按钮（可选） -->
          <div class="pt-6 border-t border-neutral-200 dark:border-neutral-800">
            <div class="flex items-center gap-3">
              <span class="text-sm font-medium text-neutral-600 dark:text-neutral-400">分享：</span>
              <button
                class="w-10 h-10 rounded-full bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center hover:bg-primary/10 hover:text-primary transition-colors duration-200"
                title="复制链接"
                onclick="navigator.clipboard.writeText(window.location.href); alert('链接已复制！')"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
